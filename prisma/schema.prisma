generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}


model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  password    String
  name        String?
  role        Role    @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
}
